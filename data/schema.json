{
  "_meta": {
    "title": "BTC Mining Intelligence Platform - Data Schema Specification",
    "version": "1.0",
    "description": "Data format specification for data agent. Use this schema when populating the JSON data files.",
    "last_updated": "2026-02-26"
  },

  "files": {
    "companies.json": {
      "description": "Master company data. Update when new companies list or delist.",
      "update_frequency": "quarterly or on major events",
      "fields": {
        "ticker": {"type": "string", "required": true, "example": "MARA", "description": "Stock ticker symbol"},
        "name": {"type": "string", "required": true, "example": "Marathon Digital Holdings", "description": "Short company name"},
        "full_name": {"type": "string", "required": true, "example": "Marathon Digital Holdings, Inc.", "description": "Legal company name"},
        "exchange": {"type": "string", "required": true, "enum": ["NASDAQ", "NYSE", "OTC"], "description": "Stock exchange"},
        "sector": {"type": "string", "required": true, "description": "Primary business segment"},
        "description": {"type": "string", "required": false, "description": "Company description"},
        "website": {"type": "string", "required": false, "description": "Company website URL"},
        "ir_url": {"type": "string", "required": false, "description": "Investor relations page URL"},
        "founded": {"type": "integer", "required": false, "description": "Year founded"},
        "headquarters": {"type": "string", "required": false, "description": "HQ location"},
        "fiscal_year_end": {"type": "string", "required": true, "example": "December", "description": "Month fiscal year ends"},
        "stock_price": {"type": "number", "required": false, "description": "Latest stock price USD"},
        "market_cap_usd_m": {"type": "number", "required": false, "description": "Market cap in USD millions"},
        "price_updated": {"type": "string", "required": false, "format": "YYYY-MM-DD", "description": "Date of last price update"},
        "active": {"type": "boolean", "required": true, "description": "Whether company is actively tracked"}
      }
    },

    "financials.json": {
      "description": "Quarterly and annual financial results. Add new record for each earnings release.",
      "update_frequency": "quarterly, within 24 hours of earnings release",
      "key_fields_priority": ["revenue_usd_m", "net_income_usd_m", "adjusted_ebitda_usd_m"],
      "fields": {
        "ticker": {"type": "string", "required": true, "description": "Stock ticker"},
        "fiscal_year": {"type": "integer", "required": true, "example": 2024, "description": "Fiscal year"},
        "fiscal_quarter": {"type": "string", "required": true, "enum": ["Q1", "Q2", "Q3", "Q4", "FY"], "description": "Fiscal period"},
        "period_label": {"type": "string", "required": true, "example": "Q3 2024", "description": "Human-readable period label"},
        "period_end_date": {"type": "string", "required": true, "format": "YYYY-MM-DD", "description": "End date of reporting period"},
        "report_date": {"type": "string|null", "required": true, "format": "YYYY-MM-DD", "description": "Actual earnings release date. NULL if not yet released"},
        "estimated_report_date": {"type": "string|null", "required": false, "format": "YYYY-MM-DD", "description": "Estimated future release date. NULL if already released or unknown"},
        "is_reported": {"type": "boolean", "required": true, "description": "TRUE if results are published"},
        "revenue_usd_m": {"type": "number|null", "required": true, "description": "Total revenue in USD millions. NULL if not yet reported"},
        "gross_profit_usd_m": {"type": "number|null", "required": false, "description": "Gross profit USD millions"},
        "operating_income_usd_m": {"type": "number|null", "required": false, "description": "Operating income/loss USD millions. Negative = loss"},
        "net_income_usd_m": {"type": "number|null", "required": true, "description": "Net income/loss USD millions. Negative = loss"},
        "adjusted_ebitda_usd_m": {"type": "number|null", "required": true, "description": "Adjusted EBITDA USD millions. Company-reported non-GAAP metric"},
        "eps_diluted": {"type": "number|null", "required": false, "description": "Diluted EPS (earnings per share)"},
        "revenue_yoy_pct": {"type": "number|null", "required": false, "description": "Revenue year-over-year change %. Positive = growth. NULL if no prior year data"},
        "gross_profit_yoy_pct": {"type": "number|null", "required": false, "description": "Gross profit YoY change %"},
        "net_income_yoy_pct": {"type": "number|null", "required": false, "description": "Net income YoY change %. NULL if both periods are losses (not meaningful)"},
        "adjusted_ebitda_yoy_pct": {"type": "number|null", "required": false, "description": "Adj EBITDA YoY change %"},
        "shares_outstanding_m": {"type": "number|null", "required": false, "description": "Diluted shares outstanding in millions"},
        "cash_and_equivalents_usd_m": {"type": "number|null", "required": false, "description": "Cash and cash equivalents USD millions (end of period)"},
        "btc_held": {"type": "integer|null", "required": false, "description": "BTC held on balance sheet (end of period)"},
        "total_debt_usd_m": {"type": "number|null", "required": false, "description": "Total debt USD millions"},
        "notes": {"type": "string", "required": false, "description": "Notable one-time items or context for the results"}
      },
      "data_sources": [
        "SEC filings (10-Q, 10-K) on EDGAR",
        "Earnings press releases on company IR websites",
        "Bloomberg, Refinitiv consensus estimates"
      ]
    },

    "operational.json": {
      "description": "Monthly operational disclosures from IR websites. Companies typically release these first week of following month.",
      "update_frequency": "monthly, within 48 hours of disclosure",
      "fields": {
        "ticker": {"type": "string", "required": true, "description": "Stock ticker"},
        "period": {"type": "string", "required": true, "format": "YYYY-MM", "example": "2024-10", "description": "Reporting month"},
        "period_label": {"type": "string", "required": true, "example": "Oct 2024", "description": "Human-readable period"},
        "report_date": {"type": "string|null", "required": true, "format": "YYYY-MM-DD", "description": "Date company published this data"},
        "btc_mined": {"type": "integer|null", "required": true, "description": "BTC produced/mined in the period"},
        "btc_held": {"type": "integer|null", "required": true, "description": "Total BTC held on balance sheet end of period"},
        "btc_sold": {"type": "integer|null", "required": false, "description": "BTC sold in period. 0 if HODL strategy"},
        "hash_rate_eh": {"type": "number|null", "required": true, "description": "Average hash rate in EH/s (exahash per second)"},
        "installed_capacity_eh": {"type": "number|null", "required": false, "description": "Total installed hash rate capacity EH/s"},
        "power_capacity_mw": {"type": "number|null", "required": false, "description": "Total power capacity in megawatts"},
        "fleet_efficiency_j_th": {"type": "number|null", "required": false, "description": "Fleet average efficiency in J/TH (Joules per terahash). Lower = more efficient"},
        "uptime_pct": {"type": "number|null", "required": false, "description": "Fleet uptime percentage"},
        "avg_power_cost_cents_kwh": {"type": "number|null", "required": false, "description": "Average power cost in cents per kWh"},
        "source_url": {"type": "string|null", "required": false, "description": "URL of the IR press release"},
        "notes": {"type": "string", "required": false, "description": "Context or notable items"}
      },
      "data_sources": [
        "Company IR websites (monthly production reports)",
        "Press releases on GlobeNewswire, BusinessWire, PRNewswire",
        "SEC Form 8-K filings"
      ]
    },

    "news.json": {
      "description": "News articles and press releases. Add relevant items daily.",
      "update_frequency": "daily",
      "fields": {
        "id": {"type": "string", "required": true, "format": "news_NNNN", "description": "Unique news ID"},
        "ticker": {"type": "string|null", "required": true, "description": "Ticker if company-specific. NULL for industry/macro news"},
        "title": {"type": "string", "required": true, "description": "Article headline"},
        "source": {"type": "string", "required": true, "description": "Publication name"},
        "url": {"type": "string|null", "required": false, "description": "Article URL. NULL if unavailable"},
        "published_at": {"type": "string", "required": true, "format": "ISO8601", "example": "2024-11-07T16:30:00Z", "description": "Publication timestamp UTC"},
        "category": {
          "type": "string", "required": true,
          "enum": ["earnings", "operations", "expansion", "regulatory", "market", "business", "sustainability", "treasury", "executive", "partnership"],
          "description": "Article category"
        },
        "sentiment": {"type": "string", "required": true, "enum": ["positive", "negative", "neutral"], "description": "Sentiment classification"},
        "sentiment_score": {"type": "number", "required": false, "min": -1, "max": 1, "description": "Sentiment score from -1 (very negative) to +1 (very positive)"},
        "summary": {"type": "string", "required": true, "max_chars": 500, "description": "Brief article summary (2-4 sentences)"},
        "tags": {"type": "array", "items": "string", "required": false, "description": "Relevant tags/keywords"}
      }
    },

    "sentiment.json": {
      "description": "Analyst ratings and social sentiment. Update ratings within 24h of new analyst note.",
      "update_frequency": "analyst_ratings: on new coverage/change; social_sentiment: daily",
      "analyst_ratings_fields": {
        "ticker": {"type": "string", "required": true},
        "analyst_firm": {"type": "string", "required": true, "description": "Investment bank/firm name"},
        "analyst_name": {"type": "string|null", "required": false, "description": "Analyst name if known"},
        "rating": {"type": "string", "required": true, "description": "Original rating string from firm"},
        "rating_normalized": {"type": "string", "required": true, "enum": ["buy", "hold", "sell"], "description": "Normalized rating for display"},
        "target_price_usd": {"type": "number|null", "required": false, "description": "Price target in USD. NULL if no target given"},
        "prev_target_price_usd": {"type": "number|null", "required": false, "description": "Previous price target if changed"},
        "date": {"type": "string", "required": true, "format": "YYYY-MM-DD", "description": "Date of rating action"},
        "action": {"type": "string", "required": true, "enum": ["initiate", "maintain", "upgrade", "downgrade", "upgrade_target", "downgrade_target", "reiterate"], "description": "Type of rating action"},
        "note": {"type": "string", "required": false, "description": "Analyst comment or rationale"}
      },
      "social_sentiment_fields": {
        "ticker": {"type": "string", "required": true},
        "date": {"type": "string", "required": true, "format": "YYYY-MM-DD"},
        "reddit_mentions_24h": {"type": "integer|null", "required": false, "description": "Reddit mentions in last 24 hours"},
        "twitter_x_mentions_24h": {"type": "integer|null", "required": false, "description": "Twitter/X mentions in last 24 hours"},
        "stocktwits_bullish_pct": {"type": "number|null", "required": false, "description": "StockTwits bullish percentage 0-100"},
        "stocktwits_bearish_pct": {"type": "number|null", "required": false, "description": "StockTwits bearish percentage 0-100"},
        "composite_score": {"type": "number|null", "required": false, "min": -1, "max": 1, "description": "Composite sentiment score"},
        "trending": {"type": "boolean", "required": false, "description": "Whether ticker is trending on social media"},
        "trend_direction": {"type": "string", "required": false, "enum": ["up", "down", "neutral"]}
      }
    }
  },

  "priority_companies": ["MARA", "RIOT", "CLSK", "CORZ", "HUT"],
  "secondary_companies": ["WULF", "IREN", "CIFR", "APLD", "BITF", "SDIG", "BTBT"],

  "financial_data_priority": {
    "must_have": ["revenue_usd_m", "net_income_usd_m", "adjusted_ebitda_usd_m", "report_date"],
    "should_have": ["gross_profit_usd_m", "eps_diluted", "cash_and_equivalents_usd_m", "btc_held"],
    "nice_to_have": ["operating_income_usd_m", "shares_outstanding_m", "total_debt_usd_m"]
  },

  "yoy_calculation_notes": [
    "revenue_yoy_pct = (current_quarter_revenue / same_quarter_last_year_revenue - 1) * 100",
    "For net_income_yoy_pct: set to null if both periods are negative (loss-to-loss comparison is not meaningful)",
    "For adjusted_ebitda_yoy_pct: calculate even if prior year was negative (improvement is meaningful)",
    "Round all percentages to 1 decimal place"
  ]
}
